# FitPath Backend Environment Variables

# The default Gemini model to use for ADK agents
MODEL_NAME=gemini-2.5-flash

# Optional: Google Gemini API Key. If left empty, the application runs in a mock fallback mode.
GEMINI_API_KEY=

# Database provider: 'sqlite' or 'mongodb'
DATABASE_PROVIDER=sqlite

# SQLite Connection URL (uses aiosqlite for async support)
DATABASE_URL=sqlite+aiosqlite:///fitpath.db

# MongoDB Connection URL (used when DATABASE_PROVIDER=mongodb)
MONGODB_URL=mongodb://localhost:27017/fitpath

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
